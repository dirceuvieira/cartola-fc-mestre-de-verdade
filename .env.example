# Example .env file for Mestre de Verdade collector
# Copy this file to .env and fill with real values (do NOT commit .env with secrets)

# Cartola API
CARTOLA_BASE_URL=https://api.cartola.globo.com

# Supabase (project URL and anon/service key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key
# For backend writes prefer the service role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (Supabase DB)
SUPABASE_DB_HOST=your-db-host.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-db-password

# Local fallback DB path (used by PoC collector if not using Supabase)
DATA_DB_PATH=data/coletor.db

# Logging
LOG_LEVEL=INFO

# Notes:
# - After copying to .env, fill in secrets and keep .env out of version control.
# - .env is already ignored by .gitignore, and .env.example is intentionally tracked.
